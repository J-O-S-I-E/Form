<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Information</title>
</head>
<body>
    <h1>User Profile</h1>

    <table border="1" cellpadding="8" cellspacing="0">
        <tr>
            <th>Field</th>
            <th>Value</th>
        </tr>
        <tr>
            <td>ID</td>
            <td><%=id %></td>
        </tr>
        <tr>
            <td>First Name</td>
            <td><%= user.firstName%></td>
        </tr>
        <tr>
            <td>Last Name</td>
            <td><%= user.lastName%></td>
        </tr>
        <tr>
            <td>Gender</td>
            <td><%=user.gender%></td>
        </tr>
        <tr>
            <td>Age</td>
            <td><%=user.age%></td>
        </tr>
    </table>
</body>
</html>